{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/swap-client/issues"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.11.0",
    "@decentralchain/bignumber": "^1.2.1",
    "long": "^5.3.2",
    "nanoid": "^5.1.5",
    "protobufjs": "^7.4.0"
  },
  "description": "WebSocket client for DecentralChain token swap aggregation — get the best swap prices across multiple DEX vendors",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.7",
    "@bufbuild/buf": "1.66.1",
    "@bufbuild/protoc-gen-es": "2.11.0",
    "@evilmartians/lefthook": "2.1.3",
    "@size-limit/preset-small-lib": "12.0.0",
    "@vitest/coverage-v8": "4.0.18",
    "jsdom": "^28.1.0",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "tsdown": "0.21.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "default": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/swap-client#readme",
  "keywords": [
    "decentralchain",
    "dcc",
    "swap",
    "dex",
    "aggregator",
    "websocket",
    "protobuf",
    "token-swap",
    "defi",
    "blockchain",
    "web3"
  ],
  "license": "MIT",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/swap-client",
  "packageManager": "npm@11.9.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decentral-America/swap-client.git"
  },
  "scripts": {
    "build": "tsdown",
    "bulletproof": "biome check --write . && npm run typecheck && npm run test",
    "bulletproof:check": "biome check . && npm run typecheck && npm run test",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "generate": "buf generate",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "postpublish": "git push",
    "postversion": "npm publish",
    "prepack": "npm run build",
    "prepare": "lefthook install",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate": "npm audit --audit-level=high && npm run lint:check && npm run typecheck && npm run test && npm run build && npm run check:publint && npm run check:exports && npm run check:size"
  },
  "sideEffects": false,
  "size-limit": [
    {
      "limit": "50 kB",
      "path": "./dist/index.mjs"
    }
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "2.0.0"
}
